# Compiled binaries
/bin/
*.exe
*.test
.idea
# Test / coverage artifacts
*.out
coverage.*

# Terraform state, plans and local config (never commit credentials or state).
# NOTE: .terraform.lock.hcl is deliberately NOT ignored — committing it pins
# provider versions, which the assignment's "exact reproduction" requires.
**/.terraform/*
*.tfstate
*.tfstate.*
tfplan*
*.tfplan
crash.log
*.tfvars
!*.tfvars.example

# OS noise
.DS_Store
